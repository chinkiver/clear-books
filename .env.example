# ===========================================
# 【必需】MySQL 数据库配置
# ===========================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=accounting
MYSQL_USER=accounting
MYSQL_PASSWORD=ClearBooksDB2024!

# ===========================================
# 【必需】Redis 配置（用于验证码、限流等）
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# 如果 Redis 没有密码，留空即可
REDIS_PASSWORD=
# Redis 数据库号（0-15，单机版 Redis 支持多个数据库）
REDIS_DATABASE=0

# ===========================================
# 【必需】JWT 密钥
# 说明：用于用户登录签名，至少 32 位随机字符串
# ===========================================
JWT_SECRET=your-super-secret-key-change-this-32chars-min

# ===========================================
# 【可选】CORS 允许的域名
# 说明：不配置则允许所有来源（*）
# 示例：http://your-domain.com,https://your-domain.com
# ===========================================
CORS_ALLOWED_ORIGINS=*
