# ===========================================
# Clear Books 生产环境配置文件
# 说明：以下密码都是你自己设置的，用于初始化服务
# 第一次部署时，Docker 会用这些值创建 MySQL/Redis 初始密码
# ===========================================

# MySQL 数据库密码（建议设置强密码）
# 说明：这是 MySQL root 用户和 accounting 用户的密码
# 格式：大小写字母+数字+符号，至少 12 位
MYSQL_ROOT_PASSWORD=ClearBooksRoot2024!
MYSQL_PASSWORD=ClearBooksDB2024!

# Redis 密码（可选，建议设置）
REDIS_PASSWORD=ClearBooksRedis2024!

# JWT 密钥（必须修改！用于用户登录签名）
# 说明：这是一个随机字符串，至少 32 位，不要泄露给他人
# 可以使用随机生成工具：https://www.random.org/strings/
JWT_SECRET=your-super-secret-key-change-this-32chars-min

# CORS 允许的域名（你的服务器地址或域名）
# 示例：http://192.168.1.100 或 https://your-domain.com
CORS_ORIGINS=http://localhost,http://127.0.0.1

# ===========================================
# 可选：腾讯云对象存储 COS 配置（用于备份）
# ===========================================
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_REGION=ap-guangzhou
# COS_BUCKET=your-bucket-name
