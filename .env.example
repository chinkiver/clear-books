# ===========================================
# Clear Books 生产环境配置文件
# 复制为 .env 并修改为你自己的配置
# ===========================================

# MySQL 数据库配置
MYSQL_ROOT_PASSWORD=YourStrongRootPassword123
MYSQL_PASSWORD=YourStrongDBPassword123

# Redis 密码
REDIS_PASSWORD=YourStrongRedisPassword123

# JWT 密钥（必须修改！使用随机字符串，至少 32 位）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-32chars

# CORS 允许的域名（多个用逗号分隔）
CORS_ORIGINS=http://localhost,http://your-domain.com,https://your-domain.com

# ===========================================
# 可选：腾讯云对象存储 COS 配置（用于备份）
# ===========================================
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_REGION=ap-guangzhou
# COS_BUCKET=your-bucket-name
