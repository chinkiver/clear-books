# ===========================================
# Clear Books 生产环境配置文件
# 以下密码都是你自己设置的，用于初始化服务
# ===========================================

# ===========================================
# 【必需】MySQL 数据库密码
# 说明：这是 MySQL root 用户和 accounting 用户的密码
# 建议：大小写字母+数字+符号，至少 12 位
# ===========================================
MYSQL_ROOT_PASSWORD=ClearBooksRoot2024!
MYSQL_PASSWORD=ClearBooksDB2024!

# ===========================================
# 【必需】JWT 密钥
# 说明：用于用户登录签名，是一个随机字符串
# 要求：至少 32 位，包含大小写字母和数字
# 生成工具：https://www.random.org/strings/
# ===========================================
JWT_SECRET=your-super-secret-key-change-this-32chars-min

# ===========================================
# 【必需】CORS 允许的域名
# 说明：填写你的服务器 IP 或域名
# 示例：http://192.168.1.100 或 https://your-domain.com
# ===========================================
CORS_ORIGINS=http://localhost,http://127.0.0.1

# ===========================================
# 【可选】Redis 密码
# 说明：如果不需要 Redis，可以留空
# ===========================================
REDIS_PASSWORD=ClearBooksRedis2024!

# ===========================================
# 【可选】腾讯云 COS 对象存储配置
# 说明：用于自动备份数据到腾讯云云端存储
# 如果不配置，备份文件只保存在本地服务器
# ===========================================
# 如何获取：
# 1. 登录 https://console.cloud.tencent.com/
# 2. 进入 对象存储 COS → 存储桶列表 → 创建存储桶
# 3. 进入 访问管理 → 访问密钥 → 创建密钥
# 4. 将 SecretId 和 SecretKey 填入下方
# ===========================================
# COS_SECRET_ID=your-secret-id-here
# COS_SECRET_KEY=your-secret-key-here
# COS_REGION=ap-guangzhou
# COS_BUCKET=clear-books-backup
